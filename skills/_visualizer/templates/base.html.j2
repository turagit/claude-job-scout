{# source_chip(source) is provided here for every Tier 1 view to inherit, per
   ../../shared-references/workspace-layout.md § "Template macro contract".
   The implementation lives in templates/html/_macros.html.j2 (single home);
   the base imports it and re-exports it as `source_chip` for in-shell use. #}
{% import "html/_macros.html.j2" as macros %}
{% set source_chip = macros.source_chip %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ data.title }} — linkedin-job-hunter</title>
<style>
{{ assets.theme_css | raw }}
</style>
</head>
<body>
<main>
{{ view_body | raw }}
</main>
<footer>Generated {{ data.generated_at }} · linkedin-job-hunter v{{ plugin_version }}</footer>
<script type="application/json" id="report-data">
{{ data | json }}
</script>
<script>
{{ assets.interactive_js | raw }}
</script>
</body>
</html>
