{# Shared HTML template macros — imported by base.html.j2 and any view that needs them.
   Single home for the structured-source → chip rendering contract documented in
   ../../shared-references/workspace-layout.md § "Template macro contract: source_chip(source)".
#}

{# source_chip(source) — render a structured {lane, provider, board} source object
   (or a bare legacy string, during the lazy tracker 2→3 upgrade) as a short,
   human-readable .tag-chip.

   Rules (mirrors the workspace-layout contract):
   - LinkedIn lane  → the board surface alone (e.g. "Search", "Top Picks").
   - External lane  → "Provider · Board" (e.g. "Greenhouse · Miro"), title-cased
                      from the slugs, board omitted when it equals the provider.
   - Bare string    → rendered verbatim.
   - Empty / missing → renders nothing.
#}
{% macro source_chip(source) -%}
{%- if source is mapping -%}
  {%- if source.lane == "linkedin" -%}
    {%- set label = source.board or source.provider or "LinkedIn" -%}
  {%- else -%}
    {%- set prov = (source.provider or "")|replace("-", " ")|title -%}
    {%- set brd = (source.board or "")|replace("-", " ")|title -%}
    {%- if brd and brd|lower != prov|lower -%}
      {%- set label = prov ~ " · " ~ brd if prov else brd -%}
    {%- else -%}
      {%- set label = prov or brd -%}
    {%- endif -%}
  {%- endif -%}
  {%- if label %}<span class="tag-chip">{{ label }}</span>{% endif -%}
{%- elif source -%}
<span class="tag-chip">{{ source }}</span>
{%- endif -%}
{%- endmacro %}
