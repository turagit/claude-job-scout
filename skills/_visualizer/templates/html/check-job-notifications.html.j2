{# schema:
   required:
     - data.title
     - data.subtitle
     - data.generated_at
     - data.filename
     - data.tier_counts
     - data.results
     - data.unread_count
#}
<header class="report-header">
  <div class="icon">🔔</div>
  <div>
    <h1>{{ data.title }}</h1>
    <div class="subtitle">{{ data.subtitle }}</div>
  </div>
</header>

{% if data.results %}
<div class="toolbar">
  <button data-sort="date" class="active">Latest ↓</button>
  <span style="flex:1"></span>
  <button data-filter="all" data-filter-attr="seen" class="active">All ({{ data.tier_counts.total }})</button>
  <button data-filter="false" data-filter-attr="seen">Unread ({{ data.unread_count }})</button>
  <button data-filter="A" data-filter-attr="tier">A-tier ({{ data.tier_counts.a }})</button>
  <button data-filter="B" data-filter-attr="tier">B-tier ({{ data.tier_counts.b }})</button>
  <button data-filter="C" data-filter-attr="tier">C-tier ({{ data.tier_counts.c }})</button>
  <button data-filter="D" data-filter-attr="tier">Filtered ({{ data.tier_counts.d }})</button>
</div>

<section>
{% for note in data.results %}
  <article id="note-{{ note.id }}" class="event-card" data-tier="{{ note.tier }}" data-seen="{% if note.seen %}true{% else %}false{% endif %}" data-sort_date="{{ note.received_at }}">
    {% if note.gate_violations and note.gate_violations|length > 0 %}
      <div class="gated-banner" style="background:var(--surface-muted,#f5f5f5);border-left:3px solid var(--danger,#c0392b);padding:8px 12px;border-radius:4px;font-size:13px">
        🚫 Filtered out — {% for v in note.gate_violations %}<strong>{{ v.kind }}</strong>{% if v.detail %} ({{ v.detail }}){% endif %}{% if not loop.last %}, {% endif %}{% endfor %}
      </div>
      <div class="meta" style="margin-top:6px;font-size:12px;color:var(--text-muted)">{{ note.title }} · {{ note.company }}{% if note.source %} · <span class="tag-chip">{{ note.source }}</span>{% endif %}</div>
    {% else %}
      <div class="header">
        <div class="title">{{ note.title }}{% if note.fresh %} <span class="tag-chip" style="background:var(--accent-from);color:#fff">⚡ apply early</span>{% endif %}</div>
        <div class="score-pill tier-{{ note.tier|lower }}">{{ note.tier }}</div>
      </div>
      <div class="meta">{{ note.company }}{% if note.location %} · {{ note.location }}{% endif %} · {{ note.received_at }}{% if note.source %} · <span class="tag-chip">{{ note.source }}</span>{% endif %}{% if note.url %} · <a href="{{ note.url }}" target="_blank" rel="noopener noreferrer" style="color:var(--accent-from);text-decoration:none;font-weight:600">View posting ↗</a>{% endif %}</div>
      {% if note.preview %}<div style="font-size:13px;color:var(--text-muted);margin-top:6px">{{ note.preview }}</div>{% endif %}
      {% if note.dimensions %}
      <table class="dim-table" style="width:100%;margin-top:10px;font-size:13px;border-collapse:collapse">
        {% for dim_name, dim in note.dimensions.items() %}
        <tr class="dim-row dim-tier-{{ dim.tier }}">
          <th style="text-align:left;padding:4px 8px;font-weight:600;color:var(--text-strong);white-space:nowrap">{{ dim_name }}</th>
          <td style="padding:4px 8px;width:32px"><span class="tier-badge tier-{{ dim.tier|lower }}" style="display:inline-block;padding:2px 8px;border-radius:999px;font-size:11px;font-weight:700">{{ dim.tier }}</span></td>
          <td class="evidence" style="padding:4px 8px;color:var(--text-muted);font-style:italic">{% for q in dim.evidence[:2] %}"{{ q }}"{% if not loop.last %}<br/>{% endif %}{% endfor %}</td>
        </tr>
        {% endfor %}
      </table>
      {% endif %}
      <div style="margin-top:8px"><button class="copy-btn" data-mark-read="note-{{ note.id }}">{% if note.seen %}Mark unread{% else %}Mark read{% endif %}</button></div>
    {% endif %}
  </article>
{% endfor %}
</section>
{% else %}
<div class="empty-state">
  <div class="icon">🔕</div>
  <div class="title">No notifications today.</div>
  <div class="hint">Make sure your LinkedIn alerts are still active — `/create-alerts` can derive a fresh set from your query plan.</div>
</div>
{% endif %}
